{
  "name": "ai-node-service",
  "version": "1.0.0",
  "description": "基于 Fastify + OpenAI 的 AI 网关服务，支持 Qwen 系列模型",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node src/index.js & node test/wait-ready.mjs && node test.mjs; kill %1 2>/dev/null",
    "lint": "eslint src/ test.mjs",
    "lint:fix": "eslint src/ test.mjs --fix",
    "format": "prettier --write src/ test.mjs public/",
    "format:check": "prettier --check src/ test.mjs public/"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "node-cache": "^5.1.2",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.8.1"
  }
}